MCP_PROXY_HOST=127.0.0.1
MCP_PROXY_PORT=8787
MCP_PROXY_CACHE_DIR=.mcp-proxy-cache
MCP_PROXY_SEARCH_TTL_SECONDS=21600
MCP_PROXY_DETAIL_TTL_SECONDS=86400
MCP_PROXY_DEBUG=false

# Refero bearer auth.
# Use either REFERO_MCP_TOKEN without "Bearer " or REFERO_AUTHORIZATION with the full header value.
REFERO_MCP_TOKEN=
# REFERO_AUTHORIZATION=Bearer ...

# Mobbin defaults to OAuth through one mcp-remote child process.
# Only set these if you intentionally want direct bearer/header mode instead of OAuth.
# MOBBIN_UPSTREAM_MODE=streamable-http
# MOBBIN_AUTHORIZATION=Bearer ...
